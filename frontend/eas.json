1. Create or Update eas.json
Create an eas.json file in your /app/frontend root directory and add the following simulator build profiles under the build configuration:
{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "simulator-ios": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "emulator-android": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug"
      }
    },

    {
  "build": {
    "preview": {
      "ios": {
        "simulator": true
      }
    },
    "production": {}
  }
},

    "preview": {
      "distribution": "internal"
    },
    "production": {}
  }
}